NoOp {
name TissueDispenser
tile_color 0xff
note_font "Verdana Bold Bold Bold"
addUserKnob {20 dispenser l "Tissue Dispenser"}
addUserKnob {22 dispense l Dispense T "import threading\n\nthis = nuke.thisNode()\nmargin = 10\n\n#create Tissue\ntissue = nuke.nodes.BackdropNode(xpos = this.xpos()+margin, ypos = this.ypos()+this.screenHeight(), bdwidth = this.screenWidth()-2*margin, bdheight = 0, tile_color = 4294967295)\ntissue.knob('name').setValue('')\ntissue.knob('knobChanged').setValue(\"if nuke.thisKnob().name() in \['xpos','ypos']:\\n\\timport math\\n\\tthis = nuke.thisNode()\\n\\tradius = this.screenWidth()/2\\n\\tdef currentPos(a):\\n\\t\\tcenterX = int( a.knob('xpos').value() + a.screenWidth()/2)\\n\\t\\tcenterY = int( a.knob('ypos').value() + a.screenHeight()/2)\\n\\t\\treturn \[centerX, centerY]\\n\\tdef checkDistance(a,b):\\n\\t\\tax = currentPos(a)\[0]\\n\\t\\tay = currentPos(a)\[1]\\n\\t\\tbx = currentPos(b)\[0]\\n\\t\\tby = currentPos(b)\[1]\\n\\t\\tdist = int(math.sqrt((ax-bx)*(ax-bx)+(ay-by)*(ay-by)))\\n\\t\\treturn dist\\n\\tdef TILEtoRGB(V):\\n\\t\\tR = (0xFF & V >> 24) / 255.0\\n\\t\\tG = (0xFF & V >> 16) / 255.0\\n\\t\\tB = (0xFF & V >> 8) / 255.0\\n\\t\\treturn R,G,B\\n\\tdef RGBtoTILE(R,G,B):\\n\\t\\treturn int('%02x%02x%02x%02x' % (R*255,G*255,B*255,255), 16 )\\n\\tdef averageColor(a,b):\\n\\t\\taR = TILEtoRGB(a)\[0]\\n\\t\\taG = TILEtoRGB(a)\[1]\\n\\t\\taB = TILEtoRGB(a)\[2]\\n\\t\\tbR = TILEtoRGB(b)\[0]\\n\\t\\tbG = TILEtoRGB(b)\[1]\\n\\t\\tbB = TILEtoRGB(b)\[2]\\n\\t\\tcR = (aR+bR)/2\\n\\t\\tcG = (aG+bG)/2\\n\\t\\tcB = (aB+bB)/2\\n\\t\\tcol = RGBtoTILE(cR,cG,cB)\\n\\t\\treturn colsmearStuff(source,target):\\n\\t\\tsourcex = currentPos(source)\[0]\\n\\t\\tsourcey = currentPos(source)\[1]\\n\\t\\ttargetx = currentPos(target)\[0]\\n\\t\\ttargety = currentPos(target)\[1]\\n\\t\\tdist = checkDistance(source,target)\\n\\t\\tdistX = targetx-sourcex\\n\\t\\tdistY = targety-sourcey\\n\\t\\tdeltax = math.ceil((distX/dist)*math.sqrt(radius+1-dist))\\n\\t\\tdeltay = math.ceil((distY/dist)*math.sqrt(radius+1-dist))\\n\\t\\ttarget.setXYpos(int(targetx-target.screenWidth()/2+0.5*deltax),int(targety-target.screenHeight()/2+0.5*deltay))\\n\\tfor n in nuke.allNodes():\\n\\t\\tif checkDistance(this,n)>radius or n.name() == this.name() or n.name() == 'TissueDispenser':\\n\\t\\t\\tpass\\n\\t\\telif this.knob('tile_color').value() == 1768576255:\\n\\t\\t\\tsmearStuff(this,n)\\n\\t\\telse:\\n\\t\\t\\tthis.knob('tile_color').setValue(averageColor(this.knob('tile_color').value(), 1768576255))\\n\\t\\t\\tnuke.delete(n)\")\n\n\ndef animate():\n\n\n\n\ttissue.knob('bdheight').setValue(tissue.knob('bdheight').value()+1)\n\ttissue.setSelected(True)\n\ttissue.setSelected(False)\n\n\n\ndef loop():\n\ttargetHeight = this.screenWidth()-2*margin\n\tif tissue.knob('bdheight').value() < targetHeight:\n\t\tanimate()\n\t\tthreading.Timer(0.01,loop).start()\n\telse:\n\t\tpass\t\nloop()" +STARTLINE}
addUserKnob {26 ""}
addUserKnob {26 credit l "by uselesscompthings" T "\nMateusz Krząstek"}
}